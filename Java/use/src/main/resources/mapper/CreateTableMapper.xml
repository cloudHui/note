<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "--//mybatis.org//DTD mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="db.business.dao.CreateTableDao">

    <insert id="insert" parameterType="db.business.entity.ServerEnterty">
        insert into ${tableName} (servertype)
        values (#{entity.servertype})
    </insert>

    <update id="createTable">
        create table ${tableName}(
         `serverid` int(11)  PRIMARY KEY AUTO_INCREMENT,
          `servertype` int(11) NOT NULL DEFAULT 0
        )
    </update>

</mapper>