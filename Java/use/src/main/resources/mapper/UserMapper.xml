<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "--//mybatis.org//DTD mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="db.business.dao.UserDao">
    <resultMap id="GameResultMap" type="db.business.entity.GameResultEntity">
        <result property="endTime" column="end_time"/>
        <result property="userName" column="username"/>
        <result property="roomId" column="roomid"/>
        <result property="bring" column="begincoin"/>
        <result property="controlLevel" column="control_level"/>
        <result property="controlId" column="control_id"/>
        <result property="win" column="wincoin"/>
    </resultMap>

    <select id="queryGameResult" resultMap="GameResultMap">
        SELECT end_time,username,roomid,begincoin,control_level,control_id,wincoin
        FROM scmj_game_result
        where end_time
        between #{end} and #{after}
        ORDER BY end_time desc
    </select>


    <resultMap id="RoomMap" type="db.business.entity.ConfigRoomEntity">
        <result property="roomId" column="room_id"/>
        <result property="name" column="name"/>
        <result property="baseScore" column="base_score"/>
    </resultMap>

    <select id="loadRoom" resultMap="RoomMap">
        SELECT room_id,name,base_score
        FROM scmj_config_room
    </select>
</mapper>