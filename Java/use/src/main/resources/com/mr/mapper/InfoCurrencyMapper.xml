<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mr.mapper.InfoCurrencyMapper">
    <resultMap id="BaseResultMap" type="com.mr.model.InfoCurrency">
        <id column="userid" jdbcType="BIGINT" property="userid"/>
        <id column="currencytype" jdbcType="INTEGER" property="currencytype"/>
        <result column="amount" jdbcType="BIGINT" property="amount"/>
        <result column="updatetime" jdbcType="TIMESTAMP" property="updatetime"/>
    </resultMap>

    <insert id="insert">
        insert into info_currency(userid, currencytype,amount, updatetime) values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.userid},#{item.currencytype},#{item.amount},#{item.updatetime})
        </foreach>
    </insert>
</mapper>