<?xml version="1.0" encoding="UTF-8"?>
<project name="servertool" basedir=".">

    <!-- 项目属性 -->
    <property name="src.dir" value="src"/>
    <property name="build.dir" value="build"/>
    <property name="classes.dir" value="${build.dir}/classes"/>
    <property name="lib.dir" value="lib"/>
    <property name="tool.output.dir" value="../../Common/Tools/Bin/server"/>
    <property name="desktop.output.dir" value="${user.home}/Desktop/work/tool"/>
    <property name="message.output.dir" value="../../Common/Tools/Bin/opcode"/>
    <property name="view.output.dir"
              value="../../Document/DevelopmentGD&amp;ConfigurationExcel/ConfigurationExcel/xls2gd_zh"/>
    <property name="view1.output.dir"
              value="../../../WarShip/Document/DevelopmentGD&amp;ConfigurationExcel/ConfigurationExcel/data/China"/>

    <!-- 主类配置 -->
    <property name="GenTools.main-class" value="com.gamer.data.ExcelMain"/>
    <property name="ViewTools.main-class" value="com.gamer.data.View"/>
    <property name="GdGenTools.main-class" value="com.gamer.data.gdg.DataBuilder"/>
    <property name="View1Tools.main-class" value="com.gamer.data.View1"/>
    <property name="NetOpcode.main-class" value="com.gamer.data.message.NetOpcodeMaker"/>
    <property name="FileTools.main-class" value="com.gamer.data.file.FileMain"/>
    <property name="McpServer.main-class" value="com.gamer.data.mpcserver.McpServer"/>
    <property name="McpExcelServer.main-class" value="com.gamer.data.mpcserver.McpExcelServerMain"/>
    <property name="McpDbServer.main-class" value="com.gamer.data.mpcserver.McpDbServerMain"/>
    <property name="McpFsServer.main-class" value="com.gamer.data.mpcserver.McpFsServerMain"/>
    <property name="McpRedisServer.main-class" value="com.gamer.data.mpcserver.McpRedisServerMain"/>

    <!-- 清理 -->
    <target name="clean">
        <delete dir="${build.dir}"/>
    </target>

    <!-- 初始化目录 -->
    <target name="init">
        <mkdir dir="${build.dir}"/>
        <mkdir dir="${classes.dir}"/>
        <mkdir dir="${tool.output.dir}"/>
        <mkdir dir="${message.output.dir}"/>
        <mkdir dir="${view.output.dir}"/>
        <mkdir dir="${view1.output.dir}"/>
    </target>

    <!-- 编译所有 -->
    <target name="compile" depends="init">
        <echo message="[INFO] 开始编译所有Java源文件..."/>
        <tstamp>
            <format property="compile.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>

        <!-- 清空classes目录，确保重新编译所有文件 -->
        <delete dir="${classes.dir}"/>
        <mkdir dir="${classes.dir}"/>

        <javac srcdir="${src.dir}" destdir="${classes.dir}"
               source="1.8" target="1.8" encoding="UTF-8"
               debug="true" includeantruntime="false">
            <classpath>
                <fileset dir="${lib.dir}">
                    <include name="**/*.jar"/>
                </fileset>
            </classpath>
        </javac>

        <!-- 复制资源文件 -->
        <echo message="[INFO] 复制资源文件..."/>
        <copy todir="${classes.dir}" overwrite="true">
            <fileset dir="${src.dir}">
                <exclude name="**/*.java"/>
            </fileset>
        </copy>

        <tstamp>
            <format property="compile.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>
        <echo message="[INFO] 编译完成，开始时间: ${compile.start.time}，结束时间: ${compile.end.time}"/>
    </target>

    <!-- 仅编译message包，只依赖domjar -->
    <target name="compile-message-only" depends="init">
        <echo message="[INFO] 开始编译message包..."/>
        <tstamp>
            <format property="compile.message.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>

        <!-- 只删除message包目录，保留其他编译结果 -->
        <delete dir="${classes.dir}/com/gamer/data/message"/>
        <mkdir dir="${classes.dir}/com/gamer/data/message"/>

        <javac srcdir="${src.dir}" destdir="${classes.dir}"
               source="1.8" target="1.8" encoding="UTF-8"
               debug="true" includeantruntime="false">
            <!-- 指定只编译message包 -->
            <include name="com/gamer/data/message/**/*.java"/>
            <classpath>
                <fileset dir="${lib.dir}">
                    <include name="dom4j-2.1.3.jar"/>
                    <include name="xmlbeans-3.1.0.jar"/>
                </fileset>
            </classpath>
        </javac>

        <!-- 复制message包的资源文件 -->
        <copy todir="${classes.dir}" overwrite="true">
            <fileset dir="${src.dir}">
                <include name="com/gamer/data/message/**/*.properties"/>
                <include name="com/gamer/data/message/**/*.xml"/>
                <include name="com/gamer/data/message/**/*.txt"/>
                <exclude name="**/*.java"/>
            </fileset>
        </copy>

        <tstamp>
            <format property="compile.message.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>
        <echo message="[INFO] message包编译完成，开始时间: ${compile.message.start.time}，结束时间: ${compile.message.end.time}"/>
    </target>

    <!-- 仅编译file包，不要任何依赖 -->
    <target name="compile-file-only" depends="init">
        <echo message="[INFO] 开始编译file包..."/>
        <tstamp>
            <format property="compile.file.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>

        <!-- 只删除file包目录，保留其他编译结果 -->
        <delete dir="${classes.dir}/com/gamer/data/file"/>
        <mkdir dir="${classes.dir}/com/gamer/data/file"/>

        <javac srcdir="${src.dir}" destdir="${classes.dir}"
               source="1.8" target="1.8" encoding="UTF-8"
               debug="true" includeantruntime="false">
            <!-- 指定只编译file包 -->
            <include name="com/gamer/data/file/**/*.java"/>
        </javac>

        <tstamp>
            <format property="compile.file.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>
        <echo message="[INFO] file包编译完成，开始时间: ${compile.file.start.time}，结束时间: ${compile.file.end.time}"/>
    </target>

    <macrodef name="create-jar">
        <attribute name="jar.name"/>
        <attribute name="main.class"/>
        <attribute name="output.dir"/>
        <attribute name="class.includes" default="**/*"/>
        <attribute name="class.excludes" default=""/>
        <element name="deps-includes"/>
        <sequential>
            <echo message="[INFO] 开始打包 @{jar.name}..."/>
            <tstamp>
                <format property="jar.@{jar.name}.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
            </tstamp>

            <mkdir dir="@{output.dir}"/>

            <jar destfile="@{output.dir}/@{jar.name}.jar" duplicate="preserve">
                <manifest>
                    <attribute name="Main-Class" value="@{main.class}"/>
                    <attribute name="Built-By" value="Ant"/>
                    <attribute name="Created-By" value="Ant"/>
                    <attribute name="Class-Path" value="."/>
                </manifest>

                <fileset dir="${classes.dir}"
                         includes="@{class.includes}"
                         excludes="@{class.excludes}"/>

                <zipgroupfileset dir="${lib.dir}">
                    <deps-includes/>
                    <patternset>
                        <exclude name="META-INF/*.SF"/>
                        <exclude name="META-INF/*.DSA"/>
                        <exclude name="META-INF/*.RSA"/>
                        <exclude name="META-INF/*.MF"/>
                    </patternset>
                </zipgroupfileset>
            </jar>

            <tstamp>
                <format property="jar.@{jar.name}.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
            </tstamp>
            <echo message="[INFO] @{jar.name} 打包完成，开始时间: ${jar.@{jar.name}.start.time}，结束时间: ${jar.@{jar.name}.end.time}"/>
            <echo message="[INFO] @{jar.name} 输出到: @{output.dir}/@{jar.name}.jar"/>
            <echo message=" "/>
        </sequential>
    </macrodef>


    <!-- 单独打包目标 -->
    <target name="p-GenTools" depends="compile">
        <echo message="[INFO] =========================================="/>
        <echo message="[INFO] 开始单独打包 GenTools..."/>
