        <echo message="[INFO] McpRedisServer 单独打包完成"/>
        <echo message="[INFO] 输出到: ${tool.output.dir}"/>
        <echo message="[INFO] 打包时间: ${package.single.McpRedisServer.start.time} 到 ${package.single.McpRedisServer.end.time}"/>
        <echo message="[INFO] =========================================="/>
    </target>

    <!-- 一键打四个拆分服务（仍会按各自依赖打包），但“打包检测”建议分别跑上面拆分目标 -->
    <target name="p-McpServer" depends="p-McpExcelServer,p-McpDbServer,p-McpFsServer,p-McpRedisServer">
        <echo message="[INFO] 四个拆分 McpServer 打包完成，输出目录: ${tool.output.dir}"/>
    </target>


    <!-- Gd生成工具打包 -->
    <target name="p-GdGen" depends="compile">
        <echo message="[INFO] =========================================="/>
        <echo message="[INFO] 开始打包 GdGen 到 View 目录..."/>
        <tstamp>
            <format property="package.single.GdGen.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>

        <!-- 1. 直接打包到 view.output.dir (不再使用 tool.output.dir) -->
        <create-jar jar.name="DataBuilder"
                    main.class="${GdGenTools.main-class}"
                    output.dir="${view.output.dir}"
                    class.includes="com/gamer/data/gdg/*">
            <deps-includes>
                <include name="poi-4.1.2.jar"/>
                <include name="poi-ooxml-4.1.2.jar"/>
                <include name="poi-ooxml-schemas-4.1.2.jar"/>
                <include name="commons-collections4-4.4.jar"/>
                <include name="commons-compress-1.19.jar"/>
                <include name="commons-math3-3.6.1.jar"/>
                <include name="xmlbeans-3.1.0.jar"/>
            </deps-includes>
        </create-jar>

        <!-- 2. 从 view.output.dir 复制一份到 view1.output.dir -->
        <echo message="[INFO] 正在同步到 view1.output.dir..."/>
        <copy file="${view.output.dir}/DataBuilder.jar"
              todir="${view1.output.dir}"
              overwrite="true"/>

        <tstamp>
            <format property="package.single.GdGen.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>
        <echo message="[INFO] GdGen 打包完成"/>
        <echo message="[INFO] 路径1: ${view.output.dir}/DataBuilder.jar"/>
        <echo message="[INFO] 路径2: ${view1.output.dir}/DataBuilder.jar"/>
        <echo message="[INFO] 打包时间: ${package.single.GdGen.start.time} 到 ${package.single.GdGen.end.time}"/>
        <echo message="[INFO] =========================================="/>
    </target>
</project>