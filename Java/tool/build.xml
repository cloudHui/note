                <include name="poi-ooxml-4.1.2.jar"/>
                <include name="poi-ooxml-schemas-4.1.2.jar"/>
                <include name="xmlbeans-3.1.0.jar"/>
                <include name="commons-collections4-4.4.jar"/>
