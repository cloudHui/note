        </create-jar>
        <tstamp>
            <format property="package.single.GenTools.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>
        <echo message="[INFO] GenTools 单独打包完成"/>
        <echo message="[INFO] 输出到: ${tool.output.dir}"/>
        <echo message="[INFO] 打包时间: ${package.single.GenTools.start.time} 到 ${package.single.GenTools.end.time}"/>
