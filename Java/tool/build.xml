    <!-- 单独打包FileTools - 专门的无依赖版本 -->
    <target name="p-FileTools" depends="compile-file-only">
        <echo message="[INFO] =========================================="/>
        <echo message="[INFO] 开始单独打包 FileTools..."/>
        <tstamp>
            <format property="package.single.FileTools.start.time" pattern="yyyy-MM-dd HH:mm:ss"/>
        </tstamp>

        <!-- 创建一个专门的、无依赖的JAR -->
        <jar destfile="${desktop.output.dir}/FileTools.jar">
            <manifest>
                <attribute name="Main-Class" value="${FileTools.main-class}"/>
                <attribute name="Built-By" value="Ant"/>
                <attribute name="Created-By" value="Ant"/>
            </manifest>

            <!-- 仅 file 包下的类文件，配置文件与 build.xml 同目录，打包时单独复制 -->
            <fileset dir="${classes.dir}" includes="com/gamer/data/file/**/*.class"/>
        </jar>

        <!-- 将与 build.xml 同目录的 initial-paths.txt 复制到 jar 同目录 -->
        <copy file="initial-paths.txt"
              todir="${desktop.output.dir}"
              overwrite="true"
              failonerror="false"/>

        <tstamp>
            <format property="package.single.FileTools.end.time" pattern="yyyy-MM-dd HH:mm:ss"/>
